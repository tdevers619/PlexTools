# -------------------------
# PLEX
# -------------------------

PLEX_URL=http://<IP_ADDRESS>:32400
PLEX_TOKEN=your_plex_token_here

# Plex library name
PLEX_LIBRARY=TV Shows

# -------------------------
# TMDB
# -------------------------

# Use the TMDb "API Read Access Token"
# NOT the old v3 API key
TMDB_TOKEN=your_tmdb_read_access_token_here

# -------------------------
# SCRIPT SETTINGS
# -------------------------

# Default show shown in prompt
DEFAULT_SHOW_NAME=Pokémon

# true = preview only
# false = actually update Plex
DRY_RUN=true

# Lock Plex title metadata after updating
LOCK_TITLE=true

# Skip Season 0 / Specials
SKIP_SPECIALS=true
